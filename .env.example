# AutoResearch Cockpit — environment configuration
# Copy this file to .env and fill in the required values.
# Place .env next to the autoresearch-cockpit binary (or in backend/ for dev).
#
# Most settings below can also be changed at runtime via the Settings page
# in the web UI. Environment variables serve as defaults on startup.

# ── Required ─────────────────────────────────────────────

# Fernet encryption key for API credentials stored in the database.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AR_ENCRYPTION_KEY=

# ── Database ─────────────────────────────────────────────
# Async connection string (used by the FastAPI app at runtime)
AR_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/autoresearch

# Synchronous connection string (used by Alembic for migrations)
AR_DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/autoresearch

# ── Timeouts ─────────────────────────────────────────────
# Maximum seconds a training subprocess may run before being killed
AR_DEFAULT_TRAINING_TIMEOUT_SECONDS=720

# Maximum seconds the LLM agent may take per step
AR_DEFAULT_AGENT_TIMEOUT_SECONDS=300

# ── CORS ─────────────────────────────────────────────────
# Restrict to specific origins in production, e.g. ["https://myhost.example.com"]
AR_CORS_ORIGINS=["*"]
