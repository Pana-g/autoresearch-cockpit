# AutoResearch Cockpit — environment configuration (optional)
#
# This file is NOT required. The app works out of the box with sensible defaults
# and auto-generates an encryption key on first run.
#
# Use this file only if you need to override defaults. Place it next to the
# autoresearch-cockpit binary (or in backend/ for dev). All settings below can
# also be changed at runtime via the Settings page in the web UI.

# ── Encryption ───────────────────────────────────────────
# Auto-generated and persisted to ~/.autoresearch/encryption.key on first run.
# Only set this if you need to use a specific key (e.g. migrating machines).
# AR_ENCRYPTION_KEY=

# ── Database ─────────────────────────────────────────────
# Default: SQLite (no setup required, database auto-created on first run)
# AR_DATABASE_URL=sqlite+aiosqlite:///data/autoresearch.db
#
# To use PostgreSQL instead, uncomment and adjust:
# AR_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/autoresearch

# ── Timeouts ─────────────────────────────────────────────
# Maximum seconds a training subprocess may run before being killed
AR_DEFAULT_TRAINING_TIMEOUT_SECONDS=720

# Maximum seconds the LLM agent may take per step
AR_DEFAULT_AGENT_TIMEOUT_SECONDS=300

# ── CORS ─────────────────────────────────────────────────
# Restrict to specific origins in production, e.g. ["https://myhost.example.com"]
AR_CORS_ORIGINS=["*"]
